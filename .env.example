# API credential는 같은 source에서 key/secret 쌍으로 제공되어야 합니다.
TOSS_INVEST_API_KEY=
TOSS_INVEST_SECRET_KEY=

# Access token
TOSS_INVEST_ACCESS_TOKEN=

# 키링 unlock 비밀번호(민감). auth login 및 credentials store에 사용됩니다. 소중히 간직하세요
TOSS_INVEST_CLI_KEYRING_PASSWORD=

# 실행 환경에서 미리 export/inject된 TOSS_INVEST_CLI_HOME만 사용되며,
# .env로는 config-home을 바꿀 수 없습니다.

# Canonical-only 계정/실주문 게이트 변수 예시
TOSS_INVEST_ACCOUNT=
TOSS_INVEST_ORDER_LIVE_APPROVED=
TOSS_INVEST_ORDER_KILL_SWITCH=
TOSS_INVEST_ACCOUNT_ALLOWLIST=